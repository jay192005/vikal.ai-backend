# Backend Environment Variables Example
# Copy this to .env and fill in your actual values
# NEVER commit .env to git!

# Flask Configuration
FLASK_ENV=production
PORT=5000

# Firebase Admin SDK Credentials (JSON string)
# Get from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Convert the JSON file to a single-line string
FIREBASE_CREDENTIALS={"type":"service_account","project_id":"your-project-id",...}

# Dataset Path
DATASET_PATH=final_data_with_year.csv

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,https://your-frontend-domain.web.app

# Optional: Secret Key for Flask sessions
SECRET_KEY=your-secret-key-here
