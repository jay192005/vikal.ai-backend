# Vercel Ignore File
# Files and directories to exclude from deployment

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
venv/
env/
ENV/

# Jupyter Notebooks (not needed in production)
*.ipynb
.ipynb_checkpoints/

# Git
.git/
.gitignore

# IDE
.vscode/
.idea/
*.swp
*.swo

# Documentation (not needed in production)
*.md
!README.md

# Frontend (deployed separately)
frontend/

# Node modules (not needed for backend)
node_modules/

# Test files
test_*.py
*_test.py

# Temporary files
*.log
*.tmp
.DS_Store
Thumbs.db

# Scripts (not needed in production)
*.bat
*.sh

# Firebase credentials (use environment variable instead)
firebase_credentials.json

# Kiro
.kiro/

# GitHub
.github/
